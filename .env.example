# Crucible — environment template. Copy to `.env.local` (gitignored) and fill in.
# Provider keys are SERVER-ONLY — never prefixed NEXT_PUBLIC_ (KERNEL_LESSONS §9).

# Supabase (fresh Crucible project)
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# Generation providers (server-only)
REPLICATE_API_TOKEN=r8_<token>
ANTHROPIC_API_KEY=sk-ant-<key>
# Optional: Google Gemini 2.5 Flash Image ("nano banana") — alternate image model
# with reference-image style anchoring. Has a free tier.
GEMINI_API_KEY=<key>
# GEMINI_MODEL=gemini-2.5-flash-image

# Cost guardrail — refuse Generate once today's estimated spend would cross this
# (USD, default 5). The hard backstop is the Replicate dashboard spend limit.
CRUCIBLE_DAILY_COST_CAP=5

# Vercel access gate (Basic Auth). Only enforced on Vercel deployments. Set BOTH in
# the Vercel project's Environment Variables, or the deployed site stays locked.
CRUCIBLE_ACCESS_USER=crucible
CRUCIBLE_ACCESS_PASSWORD=<choose-a-password>
